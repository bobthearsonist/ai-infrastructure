{
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "kapture": {
      "command": "npx",
      "args": ["-y", "kapture-mcp", "bridge"],
      "env": {
        "KAPTURE_BRIDGE_PORT": "61822"
      }
    },
    "azure-devops": {
      "command": "npx",
      "args": ["-y", "@azure-devops/mcp", "-a", "azcli", "profisee"],
      "env": {
        "AZURE_CONFIG_DIR": "/root/.azure"
      }
    }
  }
}
