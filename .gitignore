# Worktrees
.worktrees/

# Environment files with secrets
.env
*.env.local
.env.*.local

# Keep example files
!.env.example

# Client config symlinks (personal configs)
clients/**/*.json
clients/**/*.mcp
clients/**/.claude
clients/**/.yaml
clients/**/.yml

# IDE / Editor
.history/
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
*.so
.eggs/
*.egg-info/
.pytest_cache/
.mypy_cache/
.venv/

# Machine-specific MCP configs (servers.home.json, servers.windows-work.json, etc.)
mcps/stdio-proxy/servers.*.json
!mcps/stdio-proxy/servers.json
!mcps/stdio-proxy/servers.example.json
mcps/mcpx/mcp.*.json
!mcps/mcpx/mcp.example.json

# Qdrant MCP configs (machine-specific)
mcps/qdrant-mcp/servers.json
mcps/qdrant-mcp/indexer/indexer.yaml
mcps/qdrant-mcp/indexer/repos.yaml
mcps/qdrant-mcp/indexer/.index_state.json
mcps/qdrant-mcp/indexer/.index_repos_state.json
!*.example

# Docker
*.log

# Secrets (backup protection)
*.pem
*.key
*_rsa
*_dsa
*_ecdsa
*_ed25519

# MCP memory/knowledge graph data
mcps/memory/data/

# Session notes (may contain sensitive session data)
docs/session-thought.md
